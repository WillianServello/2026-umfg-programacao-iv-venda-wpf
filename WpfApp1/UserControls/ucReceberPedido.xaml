<UserControl x:Class="projetoVendas.UserControls.ucReceberPedido"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:projetoVendas.UserControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
            
             d:DesignHeight="720" d:DesignWidth="1080">

    <!-- Professor, tava muito dificil o seu, então adaptei pra algo que entenda
      { BORDER, GRID, STACKPANEL } = DIV 
        BORDER USO PRA ESTILIZAR O CONTEINER
    <materialDesign:PackIcon 
            Kind="CartOutline" 
            Width="30" 
            Height="30"
            Foreground="#F5F5F7"
            VerticalAlignment="Center"/>
    -->
    <UserControl.Resources>
        
        
        <!-- STYLE DO TITULO DE CADA TEXTBOX -->
        <Style x:Key="TextBlockPagamento" TargetType="TextBlock">
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        
        <Style x:Key="BordaPagamento" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
        
        <Style x:Key="ErroTextBox" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>
        
        <!--CLASS DE SOMBRA DE CONTEINER ESTATICO-->
        <Style x:Key="SombraEstatica" TargetType="Border">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#505050" BlurRadius="10" ShadowDepth="5" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>


        <!--CLASS DE SOMBRA DE CONTEINER COM HOVER (USANDO NA LISTA DO CARRINHO)-->
        <Style x:Key="SombraComHover" TargetType="Border">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#505050" BlurRadius="10" ShadowDepth="10" Opacity="0.1"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.BlurRadius"
                                To="28" Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.ShadowDepth"
                                To="5" Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.Opacity"
                                To="0.25" Duration="0:0:0.2"/>

                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>

                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.BlurRadius"
                                To="10" Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.ShadowDepth"
                                To="5" Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.Opacity"
                                To="0.2" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>




        <!--CLASS DE SOMBRA E SCALE COM HOVER (USADO NO PAGAMENTO)-->

        <Style x:Key="ShadowBorderStyle" TargetType="Border">

            <Setter Property="Background" Value="Transparent"/>
            
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#505050" BlurRadius="10" ShadowDepth="5" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.BlurRadius"
                                To="28" Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.ShadowDepth"
                                To="5" Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.Opacity"
                                To="0.25" Duration="0:0:0.2"/>

                           
                            <DoubleAnimation
                                Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                To="1.01" Duration="0:0:0.2"/>

                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>

                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.BlurRadius"
                                To="10" Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.ShadowDepth"
                                To="5" Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.Opacity"
                                To="0.2" Duration="0:0:0.2"/>

                            <DoubleAnimation
                                Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                To="1" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Padding="20">
            <Border Grid.Row="0" 
                    Background="White"
                    BorderThickness="1"
                    Padding="40"
                    CornerRadius="10"
                    Style="{StaticResource SombraEstatica}"
                    >
                <StackPanel Orientation="Horizontal">
                    
                    <TextBlock Text="Carrinho"
                               Foreground="#4B4B4B"
                               FontSize="30"
                               FontFamily="Arial"
                               VerticalAlignment="Center"/>
                    
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.Row="1" Padding="20">
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Border Background="White" 
                        CornerRadius="10"/>

                <!-- LISTA DO CARRINHO E PAGAMENTO (CONTEINERS) -->
                <Border Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- LISTA DO CARRINHO -->
                        <Border Grid.Column="0" 
                                Background="#F5F5F7"
                                BorderBrush="#EAEAEA"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="10"
                                Style="{StaticResource SombraEstatica}">

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Pedido.Produtos}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            
                                            <Border Background="#F5F5F7"
                                                    CornerRadius="10"
                                                    Margin="5"
                                                    Padding="20"
                                                    Style="{StaticResource SombraComHover}">
                                                
                                                <Grid VerticalAlignment="Center">
                                                    
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    

                                                        <TextBlock Grid.Column="0" 
                                                                   Text="{Binding Referencia}" 
                                                                   VerticalAlignment="Center"
                                                                   FontSize="20"
                                                                   FontFamily="Segoe UI Light"
                                                                   Margin="0,0,20,0"/>

                                                        <Image Grid.Column="1"
                                                               Source="{Binding Imagem}"
                                                               Width="100"
                                                               Height="100">
                                                            <Image.Clip>
                                                                <EllipseGeometry Center="50,50" 
                                                                                 RadiusX="60" 
                                                                                 RadiusY="60"/>
                                                            </Image.Clip>
                                                        </Image>

                                                        <TextBlock Grid.Column="2" 
                                                                   Text="{Binding Descricao}" 
                                                                   VerticalAlignment="Center"
                                                                   FontSize="20"
                                                                   FontFamily="Segoe UI Light"
                                                                   Margin="20,0,0,0"/>

                                                        <TextBlock Grid.Column="3"  
                                                                   Text="{Binding Valor}" 
                                                                   VerticalAlignment="Center"
                                                                   FontSize="20"
                                                                   FontFamily="Segoe UI Light"
                                                                   Margin="20,0,0,0"/>

                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <!-- LISTA DO PAGAMENTO -->
                        <Border  Grid.Column="2" Background="#F5F5F7" 
                                 CornerRadius="10"
                                 Margin="10"
                                 Style="{StaticResource SombraEstatica}">
                            <!-- SCROLL BASICO PRA DESCER, ANTES EU TAVA FAZENDO INDIVIDUAL E TABA FICANDO CAGADO -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <Grid>
                                    <!-- (PRA LEMBRAR) DIVIDI EM DUA LINHAS SENDO A 0 QUE OCUPA 2/3 E A OUTRA 1/3 -->
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="2*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>


                                    <!-- CARTÕES -->
                                    <Border  Grid.Row="0" Padding="20">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition  Height="Auto"/>
                                                <RowDefinition  Height="Auto"/>
                                                <RowDefinition  Height="Auto"/>
                                                <RowDefinition  Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- COMBO BOX -->
                                            <Border Grid.Row="0"  CornerRadius="5" >
                                                
                                                <StackPanel>
                                                    <TextBlock 
                                                        Text="Cartão"
                                                        Style="{StaticResource TextBlockPagamento}"/>
                                                    
                                                    <Border 
                                                        Style="{StaticResource BordaPagamento}">
                                                        
                                                        <ComboBox 
                                                            x:Name="ComboCartao"
                                                            BorderThickness="0"
                                                            Background="Transparent"
                                                            FontSize="20"
                                                            Padding="10"
                                                            materialDesign:HintAssist.Hint="Selecione um Cartão"
                                                            Validation.ErrorTemplate="{x:Null}"
                                                            ItemsSource="{Binding TiposCartao}"
                                                            SelectedItem="{Binding CartaoSelecionado,
                                                                UpdateSourceTrigger=PropertyChanged,
                                                                ValidatesOnNotifyDataErrors=True}"
                                                                LostFocus="ComboBox_LostFocus"/>
                                                    </Border>
                                                    
                                                    <!-- Validação igual no razor que consegue puxar direto -->
                                                    
                                                    <TextBlock  
                                                        Text="{Binding ElementName=ComboCartao, 
                                                        Path=(Validation.Errors)[0].ErrorContent}"
                                                        Style="{StaticResource ErroTextBox}"/>          

                                                </StackPanel>
                                            </Border>

                                            <!-- NUMERO CARTAO -->
                                            
                                                <StackPanel Grid.Row="1" Margin="0,0,0,0">
                                                    <TextBlock 
                                                        Text="Número do Cartão"
                                                        Style="{StaticResource TextBlockPagamento}"/>

                                                    <Border 
                                                        Style="{StaticResource BordaPagamento}">

                                                        <TextBox 
                                                            x:Name="NumeroCartao"
                                                            Text="{Binding NumeroCartao,
                                                            Mode=TwoWay, 
                                                            UpdateSourceTrigger=PropertyChanged,
                                                            ValidatesOnNotifyDataErrors=True}"
                                                            materialDesign:HintAssist.Hint="Informe o número do Cartão"
                                                            TextChanged="FormatarCartao"
                                                            PreviewTextInput="ApenasNumero"
                                                            Validation.ErrorTemplate="{x:Null}"
                                                            FontSize="20"
                                                            Padding="10"
                                                            BorderThickness="0"
                                                            FontWeight="Regular"
                                                            />
                                                        
                                                    </Border>
                                                        
                                                    <TextBlock  
                                                        Text="{Binding ElementName=NumeroCartao, 
                                                        Path=(Validation.Errors)[0].ErrorContent}"
                                                        Style="{StaticResource ErroTextBox}"/>
                                                    
                                                    </StackPanel>

                                            <!-- NOME CARTAO -->
                                            <StackPanel 
                                                Grid.Row="2">

                                                <TextBlock 
                                                    Text="Nome do Cartão"
                                                    Style="{StaticResource TextBlockPagamento}"/>

                                                <Border 
                                                    Style="{StaticResource BordaPagamento}">

                                                    <TextBox 
                                                        x:Name="NomeCartao"
                                                        Text="{Binding NomeCartao,
                                                        Mode=TwoWay, 
                                                        UpdateSourceTrigger=PropertyChanged,
                                                        ValidatesOnNotifyDataErrors=True}"
                                                        materialDesign:HintAssist.Hint="Informe o nome do cartão"
                                                        PreviewTextInput="ApenasLetras"
                                                        Validation.ErrorTemplate="{x:Null}"
                                                        FontSize="20"
                                                        Padding="10"
                                                        BorderThickness="0"                                                                                    
                                                        FontWeight="Regular"/>
                                                </Border>
                                                
                                                <TextBlock  
                                                    Text="{Binding ElementName=NomeCartao, 
                                                    Path=(Validation.Errors)[0].ErrorContent}"
                                                    Style="{StaticResource ErroTextBox}"/>

                                            </StackPanel>
                                            
                                            
                                            <!-- DATA -->
                                            <StackPanel Grid.Row="3">
                                                
                                                <TextBlock 
                                                    Text="Data de Válidade"
                                                    Style="{StaticResource TextBlockPagamento}"/>

                                                <Border 
                                                    Style="{StaticResource BordaPagamento}">

                                                    <TextBox 
                                                        x:Name="DataValidade"
                                                        Text="{Binding DataValidade, 
                                                        UpdateSourceTrigger=PropertyChanged,
                                                        ValidatesOnNotifyDataErrors=True}"
                                                        PreviewTextInput="ApenasNumero"
                                                        TextChanged="FormatarValidade"
                                                        MaxLength="7"
                                                      
                                                        materialDesign:HintAssist.Hint="Informe a data de validade"
                                                        Validation.ErrorTemplate="{x:Null}"
                                                        Padding="10"
                                                        FontSize="20"
                                                        FontWeight="Regular"
                                                        BorderThickness="0"/>
                                                    
                                                    
                                                </Border>
                                                
                                                <TextBlock  
                                                    Text="{Binding ElementName=DataValidade, 
                                                    Path=(Validation.Errors)[0].ErrorContent}"
                                                    Style="{StaticResource ErroTextBox}"/>
                                                
                                            </StackPanel>
                                            
                                            <!-- CVV -->
                                            <StackPanel Grid.Row="4">
                                                
                                                <TextBlock 
                                                    Text="CVV"
                                                    Style="{StaticResource TextBlockPagamento}"/>

                                                <Border 
                                                    Style="{StaticResource BordaPagamento}">

                                                    <TextBox 
                                                        x:Name="CVV"
                                                        Text="{Binding CVV,
                                                        Mode=TwoWay, 
                                                        UpdateSourceTrigger=PropertyChanged,
                                                        ValidatesOnNotifyDataErrors=True}"
                                                        materialDesign:HintAssist.Hint="Informe o CVV"
                                                        Validation.ErrorTemplate="{x:Null}"
                                                        PreviewTextInput="ApenasNumero"
                                                        TextChanged="RemoverEspacos"
                                                        MaxLength="3"
                                                        FontSize="20"
                                                        Padding="10"
                                                        BorderThickness="0"                                                                                    
                                                        FontWeight="Regular"/>
                                                </Border>

                                                <TextBlock  
                                                    Text="{Binding ElementName=CVV, 
                                                    Path=(Validation.Errors)[0].ErrorContent}"
                                                    Style="{StaticResource ErroTextBox}"/>
                                                
                                            </StackPanel>
                                            
                                        </Grid>
                                        
                                    </Border>

                                    <!-- TOTAL COMPRA -->
                                    <Border  Grid.Row="1" Background="#F5F5F7" 
                                             CornerRadius="10"
                                             Margin="10"
                                             VerticalAlignment="Bottom"
                                             Style="{StaticResource SombraEstatica}">


                                        <Grid>

                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            
                                            <Border Grid.Row="0" VerticalAlignment="Bottom" 
                                                        Padding="20"
                                                        Background="White" 
                                                        CornerRadius="10">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                    
                                                    

                                                        <TextBlock Grid.Column="0" Grid.Row="0"
                                                                       Text="Valor Total:"
                                                                       HorizontalAlignment="Left"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="20"
                                                                       FontFamily="Arial"
                                                                       FontWeight="Bold"/>

                                                        <TextBlock Grid.Column="2" Grid.Row="0"
                                                                       Text="{Binding Pedido.Total}"
                                                                       HorizontalAlignment="Right"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="20"
                                                                       FontFamily="Segoe UI Light"/>

                                                    </Grid>
                                                        <Button 
                                                        Grid.Row="1" 
                                                        Height="50" 
                                                        Margin="0,10,0,0"
                                                         Command="{Binding Finalizar}"
                                                         CommandParameter="{Binding}">
                                                        
                                                        <TextBlock 
                                                            Text="Confirmar Pedido?" 
                                                            TextAlignment="Center" 
                                                            HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"
                                                            Foreground="White"
                                                            FontSize="18"
                                                            FontWeight="Bold"/>
                                                    </Button>
                                            </StackPanel>
                                               
                                            </Border>
                                            

                                        </Grid>
                                    </Border>

                                </Grid>
                            </ScrollViewer>
                        </Border>
                        
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
