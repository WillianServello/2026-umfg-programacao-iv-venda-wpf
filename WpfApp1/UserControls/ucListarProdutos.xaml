<UserControl x:Class="projetoVendas.UserControls.ucListarProdutos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:projetoVendas.UserControls"
             mc:Ignorable="d" 
             Background="White"
             HorizontalAlignment="Center"
             d:DesignHeight="720" d:DesignWidth="1080">

    <Grid Background="#ECF0F1">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
            
        <!-- Nesta primeira grid vamos apresentar os produtos -->
        
        <Grid Grid.Row="0">
            <ScrollViewer Margin="10">
                <ListBox ItemsSource="{Binding Produtos}"
                         SelectedItem="{Binding ProdutoSelecionado}"
                         SelectionMode="Single"    
                         VerticalAlignment="Stretch"
                         HorizontalAlignment="Stretch">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="300" Height="450">
                                <StackPanel>
                                    <Border Width="300" Height="300"
                                        CornerRadius="5" Margin="5">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="1"/>
                                        </Border.Effect>

                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding Imagem}"/>
                                        </Border.Background>
                                    </Border>

                                    <TextBlock Margin="5"
                                                   Text="{Binding Referencia}"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"/>

                                    <TextBlock Margin="5"
                                                   Text="{Binding Descricao}"
                                                   FontSize="18"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"/>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Margin="5 0" Text="R$" FontSize="18" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Valor}" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>


                        <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="1">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left" 
                        VerticalAlignment="Center">

                <Button Style="{StaticResource MaterialDesignRaisedLightButton}"
                        CommandParameter="{Binding}"
                        Command="{Binding Adicionar}"
                        Content="_Adicionar"
                        Margin="10 5 10 10"
                        Foreground="Black"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                <TextBlock Text="Subtotal:" Margin="10 10 0 0" FontSize="16"/>
                <TextBlock Text="R$" FontWeight="SemiBold" Margin="10 10 0 0" FontSize="16"/>
                <TextBlock Text="{Binding Pedido.Total}" FontWeight="SemiBold" Margin="10 10 15 0" FontSize="16"/>

                <Button Style="{StaticResource MaterialDesignRaisedLightButton}"
                        CommandParameter="{Binding}"
                        Command="{Binding Receber, UpdateSourceTrigger=PropertyChanged}"
                        Content="_Receber"
                        Foreground="Black"
                        Margin="10 5 10 10"/>


            </StackPanel>
        </Grid>
            

    </Grid>
</UserControl>
